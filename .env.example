# NeuroScreen Environment Variables
# Copy this file to '.env' and fill in your keys. All are OPTIONAL — the app
# runs fully offline (localStorage + browser text-to-speech) without any keys.

# Vapi voice assistant (spoken explanation + voice Q&A of results)
# Get a PUBLIC key from https://dashboard.vapi.ai (Publishable/Web key).
VITE_VAPI_PUBLIC_KEY=your-vapi-public-key-here
# Optional but recommended: create an Assistant in the Vapi dashboard and paste
# its ID here. The app seeds it with the user's results at call time. Without an
# ID, the app tries an inline assistant (requires providers enabled on your Vapi
# account) and otherwise falls back to browser text-to-speech.
VITE_VAPI_ASSISTANT_ID=

# Supabase (optional — for future cloud sync of screenings; app uses
# localStorage by default)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
